embedding:
  model: BAAI/bge-m3
  device: auto
  batch_size: 32

retrieval:
  bm25_top_k: 40
  dense_top_k: 40
  fusion_top_k: 30
  bm25_weight: 0.45
  dense_weight: 0.55
  rerank_top_n: 15

reranker:
  model: BAAI/bge-reranker-v2-m3
  device: auto
  batch_size: 32

# ─────────────────────────────────────────────────────────────────────────────
# LLM — TensorRT-LLM 1.2 backend PyTorch (Qwen3-30B-A3B-Instruct-2507 NVFP4)
# Le nom "qwen3-30b-a3b-instruct" DOIT correspondre à SERVED_MODEL_NAME du
# service tensorrt-llm (docker-compose.gx10.yml). On sert le checkpoint NVFP4 direct.
# ─────────────────────────────────────────────────────────────────────────────
llm:
  provider: tensorrt-llm
  model: qwen3-30b-a3b-instruct
  base_url: http://tensorrt-llm:8000
  api_format: openai
  temperature: 0.1
  max_tokens: 4096
  # num_ctx non utilisé par TRT-LLM (context window fixée à la compilation : 32768 tokens)
  num_ctx: 32768
  timeout: 300
  # ───────────────────────────────────────────────────────────────────────────
  # Backends alternatifs (tous OpenAI-compatibles via le contrat LLM_URL) :
  #
  # Ollama (x86/AMD, mono-instance) :
  #   provider: ollama
  #   model: qwen2.5:14b-instruct-q4_K_M
  #   base_url: http://ollama:11434
  #   timeout: 1800
  #
  # LM Studio (poste de dev / local) :
  #   provider: lmstudio
  #   model: qwen2.5-14b-instruct
  #   base_url: http://host.docker.internal:1234/v1
  #   timeout: 1800
  # ───────────────────────────────────────────────────────────────────────────

agent:
  port: 8500
  cache_ttl: 0
  default_detail_level: standard

chunking:
  chunk_size: 800
  chunk_overlap: 100
  strategy: sentence
  include_file_context: true
  adaptive: true

chunking_strategies:
  pdf:
    strategy: sentence
    chunk_size: 512
    chunk_overlap: 50
  docx:
    strategy: paragraph
    chunk_size: 600
    chunk_overlap: 80
  xlsx:
    strategy: row_group
    rows_per_chunk: 20
    include_header: true
  pptx:
    strategy: slide
    chunk_size: 800
    chunk_overlap: 0
  msg:
    strategy: email
    chunk_size: 800
    chunk_overlap: 0
  txt:
    strategy: sentence
    chunk_size: 400
    chunk_overlap: 50

excel:
  max_rows_per_chunk: 50
  overlap_rows: 5
  enable_sql_storage: true
  sqlite_path: /app/data/excel_data.db
  include_stats: true
  detect_key_columns: true

pdf:
  enable_ocr: false
  markdown_timeout: 0
  markdown_timeout_per_page: 2.0
  ocr_dpi: 300
  max_drawings_per_page: 500

opensearch:
  host: localhost
  port: 9200
  index_name: documents

qdrant:
  host: localhost
  port: 6333
  collection_name: documents
  distance: cosine

api:
  host: 0.0.0.0
  port: 8000
  reload: false

logging:
  level: INFO
  format: '%(asctime)s - %(name)s - %(levelname)s - %(message)s'
  file: data/logs/rag_system.log

feedback:
  enabled: true
  key_users:
    - damien

ragas:
  enabled: true
  use_local_llm: true
  eval_model: qwen3-30b-a3b-instruct
  embed_model: BAAI/bge-m3
  metrics:
    - faithfulness
    - answer_relevancy
    - context_recall
  thresholds:
    faithfulness: 0.8
    answer_relevancy: 0.75
    context_recall: 0.7
  dataset_path: evaluation/datasets/

# ─────────────────────────────────────────────────────────────────────────────
# Watcher — Surveillance automatique de fichiers et réindexation RAG
# ─────────────────────────────────────────────────────────────────────────────
watcher:
  enabled: true
  watched_paths:
    - path: /app/data
      recursive: true
      index_name: documents
  polling_interval: 5.0
  debounce_seconds: 3.0
  stability_checks: 3
  stability_interval: 2.0
  max_worker_threads: 1
  worker_poll_interval: 1.0
  reconcile_interval: 300
  reconcile_on_startup: true
  allowed_extensions: []
  excluded_dirs:
    - .git
    - __pycache__
    - .venv
    - node_modules
  excluded_extensions:
    - .tmp
    - .temp
  max_file_size_mb: 500
  retry_max_attempts: 3
  retry_backoff_base: 60.0
  db_path: /app/backups/watcher/watcher.db
  api_port: 8090
  default_index_name: documents
