INSTANCE_NAME=instance-01
COMPOSE_PROFILES=gpu
API_PORT=8000
CHAT_PORT=8501
ADMIN_PORT=8080
FEEDBACK_PORT=8503
QDRANT_PORT=6333
OPENSEARCH_PORT=9200
OLLAMA_PORT=11434
OLLAMA_URL=http://ollama:11434
QDRANT_URL=http://qdrant:6333
OPENSEARCH_URL=http://opensearch:9200
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1
CUDA_VISIBLE_DEVICES=0
TZ=Europe/Paris
AUTH_SECRET=

# ── Watcher — Surveillance automatique de fichiers ────────────────────────
WATCHER_ENABLED=true
WATCHER_DB_PATH=/app/backups/watcher/watcher.db
WATCHER_PORT=8090
WATCHER_POLLING_INTERVAL=5
WATCHER_DEBOUNCE_SECONDS=3
WATCHER_MAX_FILE_SIZE_MB=500
WATCHER_RECONCILE_INTERVAL=300
WATCHER_RETRY_MAX_ATTEMPTS=3
WATCHER_WORKER_THREADS=1

# ── Mail — Module de traitement email ────────────────────────────────────────
# Activer le module mail (false par défaut en V1)
MAIL_ENABLED=false

# Chemin de la base SQLite mail (dans le volume feedbacks/)
MAIL_DB_PATH=/app/feedbacks/mail.db

# Chemin de stockage des pièces jointes (isolé, hors webroot)
MAIL_ATTACHMENTS_PATH=/app/feedbacks/mail_attachments

# Clé de chiffrement Fernet pour les secrets IMAP/SMTP
# OBLIGATOIRE en production. Générer avec :
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Si absent : clé auto-générée dans MAIL_DB_PATH/../.mail_key (non recommandé prod)
MAIL_ENCRYPTION_KEY=

# Index RAG utilisé pour répondre aux emails (nom exact de l'index ingéré pour ce client)
# Exemple : chavenay, juridique, rh-2024
MAIL_DEFAULT_INDEX=

# ── Serveur mail local de test (luciole-mail / GreenMail) ────────────────────
# Image greenmail/standalone:latest. Ports internes GreenMail : 3025 SMTP,
# 3143 IMAP, 8080 API. Ports exposés sur l'hôte pour les clients de test :
MAIL_SMTP_PORT=25         # SMTP entrant (clients LAN → GreenMail:3025)
MAIL_IMAP_PORT=143        # IMAP lecture (clients LAN → GreenMail:3143)
MAIL_ADMIN_PORT=8025      # API GreenMail (localhost → GreenMail:8080)
#
# GreenMail tourne avec -Dgreenmail.setup.test.all et -Dgreenmail.auth.disabled=true
# (voir GREENMAIL_OPTS dans le compose) : toute adresse/tout mot de passe est
# accepté, aucun script d'initialisation de comptes n'est nécessaire.

# ── Backend LLM (contrat OpenAI-compatible via LLM_URL) ──────────────────────
# LLM_URL est défini directement dans les fichiers compose (valeur ci-dessous à
# titre indicatif). Mono-instance x86/AMD (docker-compose.legacy.yml) : Ollama.
# Multi-instances ARM64/GX10 (docker-compose.instance*.yml) : backend TensorRT-LLM
# partagé sur le réseau luciole_shared.
#   LLM_URL=http://ollama:11434                 # legacy (Ollama — gestion dynamique UI)
#   LLM_URL=http://tensorrt-llm-shared:8000     # instance GX10 (TensorRT-LLM)
# Sondes alternatives lues par le code (src/generation/llm.py) si définies :
#   TRT_LLM_URL=
#   TRITON_URL=

# ── Multi-instances métier (architecture ARM64/GX10) ─────────────────────────
# Mode multi-index : chaque instance métier gère son propre index isolé.
# Défini en dur (=false) dans docker-compose.instance.yml pour le mono-index.
MULTI_INDEX_MODE=false
# Profil métier appliqué au query rewriter (voir config/profiles/README.md).
# generic = aucune règle ; eolien = 15 règles ICPE historiques archivées.
BUSINESS_PROFILE=generic
# Emplacement hôte des modèles HuggingFace montés dans les conteneurs
# (utilisé par docker-compose.instance*.yml).
HF_MODELS_PATH=./models/huggingface
