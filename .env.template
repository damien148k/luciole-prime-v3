INSTANCE_NAME=instance-01
COMPOSE_PROFILES=gpu
API_PORT=8000
CHAT_PORT=8501
ADMIN_PORT=8080
FEEDBACK_PORT=8503
QDRANT_PORT=6333
OPENSEARCH_PORT=9200
OLLAMA_PORT=11434
OLLAMA_URL=http://ollama:11434
QDRANT_URL=http://qdrant:6333
OPENSEARCH_URL=http://opensearch:9200
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1
CUDA_VISIBLE_DEVICES=0
TZ=Europe/Paris
AUTH_SECRET=

# ── Watcher — Surveillance automatique de fichiers ────────────────────────
WATCHER_ENABLED=true
WATCHER_DB_PATH=/app/backups/watcher/watcher.db
WATCHER_PORT=8090
WATCHER_POLLING_INTERVAL=5
WATCHER_DEBOUNCE_SECONDS=3
WATCHER_MAX_FILE_SIZE_MB=500
WATCHER_RECONCILE_INTERVAL=300
WATCHER_RETRY_MAX_ATTEMPTS=3
WATCHER_WORKER_THREADS=1

# ── Mail — Module de traitement email ────────────────────────────────────────
# Activer le module mail (false par défaut en V1)
MAIL_ENABLED=false

# Chemin de la base SQLite mail (dans le volume feedbacks/)
MAIL_DB_PATH=/app/feedbacks/mail.db

# Chemin de stockage des pièces jointes (isolé, hors webroot)
MAIL_ATTACHMENTS_PATH=/app/feedbacks/mail_attachments

# Clé de chiffrement Fernet pour les secrets IMAP/SMTP
# OBLIGATOIRE en production. Générer avec :
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Si absent : clé auto-générée dans MAIL_DB_PATH/../.mail_key (non recommandé prod)
MAIL_ENCRYPTION_KEY=

# Index RAG utilisé pour répondre aux emails (nom exact de l'index ingéré pour ce client)
# Exemple : chavenay, juridique, rh-2024
MAIL_DEFAULT_INDEX=

# ── Serveur mail local de test (luciole-mail / Stalwart) ─────────────────────
# Ports exposés sur le LAN pour les clients de test (Thunderbird, Outlook)
MAIL_SMTP_PORT=25         # SMTP entrant (clients LAN → luciole-mail)
MAIL_IMAP_PORT=143        # IMAP lecture (clients LAN + Luciole interne)
MAIL_ADMIN_PORT=8025      # Interface web admin Stalwart (localhost seulement)
#
# Comptes de test (créés via : docker exec luciole-mail-<INSTANCE> /bin/sh /init/init-accounts.sh)
#   luciole@local.lan  /  luciole2024   ← boîte principale Luciole
#   testeur@local.lan  /  testeur2024   ← boîte du testeur humain
#   demo@local.lan     /  demo2024      ← optionnel
