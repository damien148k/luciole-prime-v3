# Forcer LF pour les scripts shell et fichiers texte
*.sh           text eol=lf
*.py           text eol=lf
*.yml          text eol=lf
*.yaml         text eol=lf
*.json         text eol=lf
*.md           text eol=lf
*.txt          text eol=lf
*.css          text eol=lf
*.html         text eol=lf
.gitignore     text eol=lf
.env.template  text eol=lf
LICENSE        text eol=lf
Dockerfile*    text eol=lf

# Garder CRLF pour PowerShell (Windows)
*.ps1          text eol=crlf

# Binaires
*.png          binary
*.woff2        binary