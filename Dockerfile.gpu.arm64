# =============================================================================
# Dockerfile.gpu (ARM64 / DGX Spark GX10 — GB10 Blackwell, sm_121)
# Luciole RAG — services : agent, admin-ui, chat, feedback, watcher
#
# Différences clés vs la version x86 CUDA 12.1 :
#   - Base CUDA 12.8 (compatible Blackwell sm_121 ; dispo en linux/arm64 SBSA)
#   - Ubuntu 24.04 (python3.11 -> on garde 3.11 via deadsnakes n'est pas requis :
#     24.04 fournit python3.12 ; on installe python3.11 via apt si dispo, sinon 3.12)
#   - Wheels torch cu128 (arm64) au lieu de cu121
#
# ⚠️ Cette image DOIT être construite pour linux/arm64.
#    En cross-build QEMU depuis x86, le build réussit (pip installe des wheels,
#    pas de compilation GPU), mais l'exécution n'est valide QUE sur un hôte
#    arm64 + GPU Blackwell (le GX10). Ne pas exécuter sur x86.
# =============================================================================

FROM nvidia/cuda:12.8.1-runtime-ubuntu24.04

LABEL maintainer="Luciole RAG Team"
LABEL description="Luciole RAG — embedding + reranking GPU (arm64/GB10), LLM via TensorRT-LLM"

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV PYTHONPATH=/app
ENV HF_HOME=/app/models/huggingface
ENV SENTENCE_TRANSFORMERS_HOME=/app/models/huggingface
ENV EASYOCR_MODULE_PATH=/app/models/easyocr
ENV DEBIAN_FRONTEND=noninteractive
ENV PIP_TRUSTED_HOST="pypi.org pypi.python.org files.pythonhosted.org download.pytorch.org"

# Ubuntu 24.04 : python3.12 par défaut. On installe aussi le venv/pip.
# (Le code Luciole est compatible 3.11/3.12.)
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 \
    python3-venv \
    python3-pip \
    curl \
    libgl1 \
    libglib2.0-0 \
    libsm6 \
    libxext6 \
    libxrender1 \
    libgomp1 \
    ca-certificates \
    tzdata \
    && rm -rf /var/lib/apt/lists/* \
    && ln -sf /usr/bin/python3 /usr/bin/python \
    && update-ca-certificates

# pip d'Ubuntu 24.04 exige --break-system-packages (PEP 668) OU un venv.
# On utilise un venv pour rester propre.
ENV VIRTUAL_ENV=/opt/venv
RUN python3 -m venv $VIRTUAL_ENV
ENV PATH="$VIRTUAL_ENV/bin:$PATH"

WORKDIR /app

COPY rag-system/setup/requirements-linux-gpu.txt ./requirements.txt

# torch/vision/audio en arm64 pour Blackwell : index cu128
RUN pip install --no-cache-dir \
    --trusted-host download.pytorch.org --trusted-host pypi.org --trusted-host files.pythonhosted.org \
    torch torchvision torchaudio --index-url https://download.pytorch.org/whl/cu128

RUN pip install --no-cache-dir \
    --trusted-host pypi.org --trusted-host files.pythonhosted.org \
    -r requirements.txt

COPY rag-system/src/ ./src/
COPY rag-system/pics/ ./pics/

RUN mkdir -p /app/config /app/evaluation /app/feedbacks \
             /app/models/huggingface /app/models/easyocr

CMD ["python", "-m", "uvicorn", "src.agent.api:app", "--host", "0.0.0.0", "--port", "8000"]
